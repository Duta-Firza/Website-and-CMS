# ─────────────────────────────────────────────────────────────
# PT Duta Firza website — environment variables
# Copy this file to `.env.local` and fill in actual values.
# ─────────────────────────────────────────────────────────────

# MongoDB (self-hosted on GCP Compute Engine e2-small, asia-southeast2-a)
# Format: mongodb://<user>:<pass>@<internal-ip>:27017/<dbname>?authSource=admin
MONGODB_URI="mongodb://duta-app:CHANGE_ME@10.x.x.x:27017/dutafirza?authSource=admin"

# NextAuth.js v5
# Generate secret: openssl rand -base64 48
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_48_BYTE_BASE64_STRING"
NEXTAUTH_URL="http://localhost:3000"

# Resend (transactional email) — free tier, 3000/month
# Get key from https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
# Verified sender domain (must match dutafirza.com DNS records)
RESEND_FROM_EMAIL="noreply@dutafirza.com"
# Inquiry destination (Solutions / Trading / Manufacturing / EPC forms)
INQUIRY_TO_EMAIL="sales@dutafirza.com"
# Contact page form destination
CONTACT_TO_EMAIL="info@dutafirza.com"

# Public site URL (used in metadata, OG tags, sitemap)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Seed script credentials (used by `pnpm seed` to create the initial super-admin)
SEED_ADMIN_EMAIL="admin@dutafirza.com"
SEED_ADMIN_PASSWORD="changeme-min-12-chars"

# Google Cloud Storage (media uploads from CMS)
# 1. Create bucket (region asia-southeast2) and grant `allUsers` -> "Storage Object Viewer"
# 2. Create service account with role "Storage Object Admin" scoped to the bucket
# 3. Provide credentials via ONE of:
#    a) Local key file (recommended for local dev) — point at the JSON path:
#       GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/service-account.json"
#    b) Inline base64 (recommended for serverless / no-filesystem deploys):
#       GCS_CREDENTIALS_JSON="$(base64 -w0 service-account.json)"
#    If both are set, GCS_CREDENTIALS_JSON wins.
GCS_BUCKET="duta-firza-media"
GCS_PROJECT_ID="duta-firza-prod"
GOOGLE_APPLICATION_CREDENTIALS=""
GCS_CREDENTIALS_JSON=""
# Root prefix prepended to every object (useful when sharing a bucket with other
# projects, or separating staging vs prod). Empty disables prefixing.
# Examples: "duta-firza", "duta-firza/staging", "tenants/abc123"
GCS_FOLDER="duta-firza"
# Optional override; defaults to https://storage.googleapis.com/<GCS_BUCKET>
# GCS_PUBLIC_URL_BASE="https://media.dutafirza.com"
